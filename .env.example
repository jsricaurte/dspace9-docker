# =============================================================
# .env — Configuración de DSpace 9
#
# Copia este archivo:   cp .env.example .env
# Edita los valores:    nano .env
# =============================================================

# ── Base de datos ──────────────────────────────────────────
POSTGRES_USER=dspace
POSTGRES_PASSWORD=CAMBIA_ESTA_CLAVE_AHORA
POSTGRES_DB=dspace

# ── Nombre del repositorio (aparece en la interfaz web) ────
DSPACE_NAME=Repositorio Institucional Universidad

# ── IP o dominio del servidor ───────────────────────────────
# Para conocer la IP de tu servidor:
#   ip a | grep "inet " | grep -v 127
#
# Ejemplos válidos:
#   Red interna:  192.168.1.100
#   IP pública:   203.0.113.45
#   Dominio:      repositorio.universidad.edu.co
DSPACE_HOST=CAMBIA_POR_TU_IP_O_DOMINIO
